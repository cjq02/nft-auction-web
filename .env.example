# API
VITE_API_BASE_URL=http://localhost:9080

# 合约（Sepolia 示例）
VITE_CHAIN_ID=11155111
VITE_AUCTION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# WalletConnect（可选）
VITE_WALLETCONNECT_PROJECT_ID=

# WETH 合约（个人中心「兑换 WETH」用，默认 Sepolia）
# VITE_WETH_ADDRESS=0xfFf9976782d46CC05630D1f6eBAb18b2324d6B14

# 支持的 ERC20 出价代币（JSON 数组，合约要求 decimals=18 且已设置 setTokenPriceFeed）
# faucetMinEth 可选：有此字段时显示「充值」按钮，用 ETH 调用 mint() 获取测试代币
# adminMint 可选：为 true 时标识为管理员铸造代币，管理页「代币铸造」中可选
# VITE_SUPPORTED_TOKENS=[{"address":"0x...","symbol":"USDC","decimals":18}]
# CNH 示例（管理员铸造）：{"address":"0x...","symbol":"CNH","decimals":18,"adminMint":true}
# TST 示例（水龙头）：{"address":"0x28e53133931Be5ca1459BcA3D705b4631C05F9F2","symbol":"TST","decimals":18,"faucetMinEth":"0.001"}
